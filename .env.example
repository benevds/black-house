# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA suba o arquivo ".env" (com chaves reais) para o GitHub.

# --- Chave da API de IA ---
# Pode ser uma chave da OpenAI (platform.openai.com) ou de um provedor
# compatível com a API da OpenAI, como a Groq (gratuita).
OPENAI_API_KEY=


# Modelo a ser usado
OPENAI_MODEL=gpt-4o-mini

# Deixe OPENAI_BASE_URL vazio para usar a OpenAI oficial.
# Para usar a Groq (gratuita e rápida) em vez da OpenAI, descomente:
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=

# --- Banco de dados ---
DB_PATH=arena_marina.db

